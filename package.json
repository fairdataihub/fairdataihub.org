    "scripts:gallery_id": "tsx scripts/gallery_id.ts",
    "cypress:open": "cypress open",
    "cypress:run": "cypress run --browser chrome --headless \"cypress/e2e/**/*.cy.js\"",
    "reset": "rm -rf node_modules .next && pnpm install"
